{
  "name": "clickbench",
  "description": "Indexes the ClickBench dataset and runs OpenSearch PPL queries to benchmark analytical use case performance",
  "default": true,
  "schedule": [
    {
          "operation": {
            "operation-type": "put-settings",
            "body": {
              "transient": {
                  "plugins.ppl.syntax.legacy.preferred": "{{legacy_syntax | default("false")}}"
              }
            }
          }
    },
    {% with default_index_settings={}, index_name="clickbench" %}
    {{ benchmark.collect(parts="../../common_operations/workload_setup.json") }},
    {% endwith %}
    {{ benchmark.collect(parts="ppl/clickbench-schedule.json") }}
  ]
},
{
  "name": "clickbench-test",
  "description": "Lightweight test procedure for validating ClickBench workload setup and basic functionality",
  "default": false,
  "schedule": [
    {% with default_index_settings={}, index_name="clickbench" %}
    {{ benchmark.collect(parts="../../common_operations/workload_setup.json") }},
    {% endwith %}
    {{ benchmark.collect(parts="ppl/test-schedule.json") }}
  ]
},
{
  "name": "dsl-clickbench",
  "description": "Indexes the whole document corpus using OpenSearch default settings and runs DSL (Domain-Specific Language) queries. The DSL queries were converted from PPL via OpenSearch's _plugins/_sql/_explain API.",
  "default": false,
  "schedule": [
    {% with default_index_settings={}, index_name="clickbench" %}
    {{ benchmark.collect(parts="../../common_operations/workload_setup.json") }},
    {% endwith %}
    {{ benchmark.collect(parts="dsl/dsl-clickbench-schedule.json") }}
  ]
},
{
  "name": "dsl-clickbench-snapshot",
  "description": "Indexes the whole document corpus using OpenSearch default settings and runs DSL (Domain-Specific Language) queries. The DSL queries were converted from PPL via OpenSearch's _plugins/_sql/_explain API.",
  "default": false,
  "schedule": [
    {{ benchmark.collect(parts="common/snapshot-ops.json") }},
    {{ benchmark.collect(parts="dsl/dsl-clickbench-schedule.json") }}
  ]
},
{
  "name": "dsl-clickbench-test",
  "description": "Lightweight test procedure for validating ClickBench workload setup and basic functionality. Runs DSL (Domain-Specific Language) queries. The DSL queries were converted from PPL via OpenSearch's _plugins/_sql/_explain API.",
  "default": false,
  "schedule": [
    {% with default_index_settings={}, index_name="clickbench" %}
    {{ benchmark.collect(parts="../../common_operations/workload_setup.json") }},
    {% endwith %}
    {{ benchmark.collect(parts="dsl/dsl-clickbench-test-schedule.json") }}
  ]
},
{
  "name": "dsl-clickbench-streaming",
  "description": "Runs a subset of DSL queries for streaming benchmarks. Includes Q13, Q16, Q22, Q34-Q39.",
  "default": false,
  "schedule": [
    {{ benchmark.collect(parts="common/snapshot-ops.json") }},
    {{ benchmark.collect(parts="dsl/dsl-clickbench-schedule-streaming.json") }}
  ]
},
{
  "name": "datafusion-ppl",
  "description": "Indexes the ClickBench dataset and runs OpenSearch PPL queries to benchmark analytical use case performance. Specific to the datafusion branch.",
  "default": false,
  "schedule": [
    {
          "operation": {
            "operation-type": "put-settings",
            "body": {
              "transient": {
                  "plugins.ppl.syntax.legacy.preferred": "{{legacy_syntax | default("false")}}"
              }
            }
          }
    },
    {% with default_index_settings={}, index_name="clickbench" %}
    {{ benchmark.collect(parts="../../common_operations/delete_index.json") }},
    {{ benchmark.collect(parts="../../common_operations/create_index.json") }},
    {{ benchmark.collect(parts="../../common_operations/check_cluster_health.json") }},
    {{ benchmark.collect(parts="../../common_operations/index_append.json") }},
    {% endwith %}
    {
      "operation": "flush-index",
      "warmup-iterations": {{ flush_index_warmup_iterations or warmup_iterations | default(1) | tojson }},
      "iterations": {{ flush_index_iterations or test_iterations | default(1) | tojson }},
      "target-throughput": {{ flush_index_target_throughput or target_throughput | default(1) | tojson }},
      "clients": {{ flush_index_clients or search_clients | default(1) }}
    },
    {{ benchmark.collect(parts="ppl/mustang-clickbench-schedule.json") }}
  ]
},
{
      "name": "streaming-agg-longevity-test",
      "description": "Longevity test for streaming aggregation queries in clickbench",
      "default": false,
      "schedule": [
        {
          "parallel": {
            "tasks": [
              {
                "operation": "dsl-q13-search-phrase-count",
                "time-period": {{ dsl_q13_search_phrase_count_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ dsl_q13_search_phrase_count_target_throughput or target_throughput | default(2) | tojson }},
                "clients": {{ dsl_q13_search_phrase_count_clients or search_clients | default(1) }}
              },
              {
                "operation": "dsl-q16-user-activity",
                "time-period": {{ dsl_q16_user_activity_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ dsl_q16_user_activity_target_throughput or target_throughput | default(2) | tojson }},
                "clients": {{ dsl_q16_user_activity_clients or search_clients | default(1) }}
              },
              {
                "operation": "dsl-q22-google-search-phrases",
                "time-period": {{ dsl_q22_google_search_phrases_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ dsl_q22_google_search_phrases_target_throughput or target_throughput | default(2) | tojson }},
                "clients": {{ dsl_q22_google_search_phrases_clients or search_clients | default(1) }}
              },
              {
                "operation": "dsl-q34-url-popularity",
                "time-period": {{ dsl_q34_url_popularity_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ dsl_q34_url_popularity_target_throughput or target_throughput | default(2) | tojson }},
                "clients": {{ dsl_q34_url_popularity_clients or search_clients | default(1) }}
              },
              {
                "operation": "dsl-q35-url-with-constant",
                "time-period": {{ dsl_q35_url_with_constant_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ dsl_q35_url_with_constant_target_throughput or target_throughput | default(2) | tojson }},
                "clients": {{ dsl_q35_url_with_constant_clients or search_clients | default(1) }}
              },
              {
                "operation": "dsl-q36-client-ip-variations",
                "time-period": {{ dsl_q36_client_ip_variations_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ dsl_q36_client_ip_variations_target_throughput or target_throughput | default(2) | tojson }},
                "clients": {{ dsl_q36_client_ip_variations_clients or search_clients | default(1) }}
              },
              {
                "operation": "dsl-q37-counter-62-urls",
                "time-period": {{ dsl_q37_counter_62_urls_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ dsl_q37_counter_62_urls_target_throughput or target_throughput | default(2) | tojson }},
                "clients": {{ dsl_q37_counter_62_urls_clients or search_clients | default(1) }}
              },
              {
                "operation": "dsl-q38-counter-62-titles",
                "time-period": {{ dsl_q38_counter_62_titles_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ dsl_q38_counter_62_titles_target_throughput or target_throughput | default(2) | tojson }},
                "clients": {{ dsl_q38_counter_62_titles_clients or search_clients | default(1) }}
              },
              {
                "operation": "dsl-q39-counter-62-links",
                "time-period": {{ dsl_q39_counter_62_links_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ dsl_q39_counter_62_links_target_throughput or target_throughput | default(2) | tojson }},
                "clients": {{ dsl_q39_counter_62_links_clients or search_clients | default(1) }}
              }
            ]
          }
        }
      ]
    }
